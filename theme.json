{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1280px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "ivory", "name": "Ivory", "color": "#F8F5EF" },
        { "slug": "porcelain", "name": "Porcelain", "color": "#FDFCF9" },
        { "slug": "linen", "name": "Linen", "color": "#EFE9DF" },
        { "slug": "sage", "name": "Soft Sage", "color": "#A7B397" },
        { "slug": "olive", "name": "Olive", "color": "#66785F" },
        { "slug": "forest-olive", "name": "Forest Olive", "color": "#465443" },
        { "slug": "copper", "name": "Copper", "color": "#9A6B46" },
        { "slug": "charcoal", "name": "Charcoal", "color": "#2E2E2B" },
        { "slug": "muted-grey", "name": "Muted Grey", "color": "#66635D" }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "body",
          "name": "Source Sans 3",
          "fontFamily": "\"Source Sans 3\", system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
        },
        {
          "slug": "heading",
          "name": "Cormorant Garamond",
          "fontFamily": "\"Cormorant Garamond\", Georgia, serif"
        },
        {
          "slug": "accent",
          "name": "Instrument Serif",
          "fontFamily": "\"Instrument Serif\", Georgia, serif"
        }
      ],
      "fontSizes": [
        { "slug": "small", "name": "Small", "size": "0.875rem" },
        { "slug": "medium", "name": "Medium", "size": "1rem" },
        { "slug": "large", "name": "Large", "size": "1.25rem" },
        { "slug": "x-large", "name": "Extra Large", "size": "clamp(1.8rem, 4vw, 2.8rem)" },
        { "slug": "display", "name": "Display", "size": "clamp(2.8rem, 7vw, 5.8rem)" }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "em", "%", "vw", "vh"]
    }
  },
  "styles": {
    "color": {
      "background": "#F8F5EF",
      "text": "#2E2E2B"
    },
    "spacing": {
      "blockGap": "1.5rem"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|body",
      "fontSize": "1rem",
      "lineHeight": "1.7"
    },
    "elements": {
      "heading": {
        "color": { "text": "#2E2E2B" },
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "600",
          "lineHeight": "1.08"
        }
      },
      "link": {
        "color": { "text": "#66785F" },
        ":hover": { "color": { "text": "#9A6B46" } }
      },
      "button": {
        "border": { "radius": "5px" },
        "color": { "background": "#465443", "text": "#FDFCF9" },
        "typography": { "fontFamily": "var:preset|font-family|body", "fontWeight": "700" }
      }
    },
    "blocks": {
      "core/quote": {
        "border": { "left": { "color": "#9A6B46", "width": "3px" } },
        "typography": { "fontFamily": "var:preset|font-family|accent", "fontSize": "1.35rem" }
      }
    }
  }
}